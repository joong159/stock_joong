# ==========================================
# 토스증권 Open API 인증 정보 설정 파일
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# .env 파일은 절대 GitHub 등 공유 저장소에 올리지 마세요!
# ==========================================

# 토스증권 개발자 센터에서 발급받은 API 키
TOSS_CLIENT_ID=your_client_id_here
TOSS_CLIENT_SECRET=your_client_secret_here

# Open API 기본 주소 (실운영 환경)
TOSS_BASE_URL=https://openapi.tossinvest.com
